# ── LLM ──────────────────────────────────────────────────────────────
# LLM 模型路径（MLX 用目录，LiteRT-LM 用 .litertlm 文件）。
# 未设置时自动从 HuggingFace 下载 gemma-4-E2B-it。
# MODEL_PATH=$HOME/models/llm/Qwen3.6-A3B-opus-mxfp4-h

# SYSTEM_PROMPT=自定义系统提示词

# 服务器端口（默认：9091）
# PORT=9091

# LLM 生成参数
# MAX_TOKENS=192
# TEMPERATURE=0.2
# LONG_MAX_TOKENS=4096

# 对话历史保留轮数上限（默认：20）
# MAX_HISTORY_TURNS=20

# ── ASR（语音识别）──────────────────────────────────────────────────
# 后端："qwen" 或 "none"（未设置时从 ASR_MODEL_PATH 自动检测）
# ASR_BACKEND=qwen

# Qwen3-ASR 模型目录路径或 HuggingFace repo id。
# 未设置时启动脚本自动从 ~/models/asr/ 检测。
# ASR_MODEL_PATH=$HOME/models/asr/Qwen3-ASR-0.6B-4bit

# ASR 识别语言（默认：chinese）
# ASR_LANGUAGE=chinese

# ASR 最大 token 数（默认：4096）
# ASR_MAX_TOKENS=4096

# 自定义 ASR 提示词（可选）
# ASR_SYSTEM_PROMPT=

# ── TTS（语音合成）──────────────────────────────────────────────────
# 设为 1 完全禁用 TTS。
# DISABLE_TTS=

# 强制指定 TTS 后端："say" / "system" / "macos"（仅 macOS）
# TTS_BACKEND=

# ── Qwen3-TTS ───────────────────────────────────────────────────────
# Qwen3-TTS 模型目录路径。
# 未设置时启动脚本自动从 ~/models/tts/ 检测。
# TTS_MODEL_PATH=$HOME/models/tts/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit

# Qwen TTS 语言（默认：chinese）
# QWEN_TTS_LANGUAGE=chinese

# Qwen TTS 说话人声音（默认：serena）
# QWEN_TTS_SPEAKER=serena

# Qwen TTS 指令提示（可选）
# QWEN_TTS_INSTRUCT=自然、清晰、亲切，适合中文日常对话。

# Qwen TTS 声音设计提示（用于 voice_design 模型类型）
# QWEN_TTS_VOICE_DESIGN=一个自然、清晰、温和的中文女声，适合日常对话。

# Qwen TTS 语速（默认：1.0）
# QWEN_TTS_SPEED=1.0

# ── Kokoro TTS ──────────────────────────────────────────────────────
# Kokoro MLX 模型目录路径。
# KOKORO_MODEL_PATH=$HOME/models/tts/Kokoro-82M-bf16

# Kokoro ONNX 模型和声音文件路径。
# KOKORO_ONNX_MODEL_PATH=$HOME/models/tts/kokoro-v1.0.onnx
# KOKORO_ONNX_VOICES_PATH=$HOME/models/tts/voices-v1.0.bin

# 在 Apple Silicon 上也强制使用 Kokoro ONNX 后端（由 run-parlor.sh 设置）。
# KOKORO_ONNX=

# ── macOS 系统 TTS ─────────────────────────────────────────────────
# SYSTEM_TTS_VOICE=Tingting
# SYSTEM_TTS_RATE=180
