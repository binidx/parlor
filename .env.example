# ── LLM ──────────────────────────────────────────────────────────────
# Path to the LLM model (directory for MLX, .litertlm file for LiteRT-LM).
# If unset, auto-downloads gemma-4-E2B-it from HuggingFace.
# MODEL_PATH=$HOME/models/llm/Qwen3.6-A3B-opus-mxfp4-h

# Server port (default: 8000; shell scripts default to 9091)
# PORT=9091

# LLM generation parameters
# MAX_TOKENS=192
# TEMPERATURE=0.2
# LONG_MAX_TOKENS=4096

# ── ASR (Speech-to-Text) ────────────────────────────────────────────
# Backend: "qwen" or "none" (auto-detected from ASR_MODEL_PATH if unset)
# ASR_BACKEND=qwen

# Path to Qwen3-ASR model directory or HuggingFace repo id.
# If unset, the shell scripts auto-detect from ~/models/asr/.
# ASR_MODEL_PATH=$HOME/models/asr/Qwen3-ASR-0.6B-4bit

# ASR language (default: chinese)
# ASR_LANGUAGE=chinese

# ASR max tokens (default: 4096)
# ASR_MAX_TOKENS=4096

# Custom system prompt for ASR (optional)
# ASR_SYSTEM_PROMPT=

# ── TTS (Text-to-Speech) ────────────────────────────────────────────
# Set to 1 to disable TTS entirely.
# DISABLE_TTS=

# Force a specific TTS backend: "say" / "system" / "macos" (macOS only)
# TTS_BACKEND=

# ── Qwen3-TTS ───────────────────────────────────────────────────────
# Path to Qwen3-TTS model directory.
# If unset, the shell scripts auto-detect from ~/models/tts/.
# TTS_MODEL_PATH=$HOME/models/tts/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit

# Qwen TTS language (default: chinese)
# QWEN_TTS_LANGUAGE=chinese

# Qwen TTS speaker voice (default: serena)
# QWEN_TTS_SPEAKER=serena

# Qwen TTS instruction prompt (optional)
# QWEN_TTS_INSTRUCT=自然、清晰、亲切，适合中文日常对话。

# Qwen TTS voice design prompt (for voice_design model type)
# QWEN_TTS_VOICE_DESIGN=一个自然、清晰、温和的中文女声，适合日常对话。

# Qwen TTS speech speed (default: 1.0)
# QWEN_TTS_SPEED=1.0

# ── Kokoro TTS ──────────────────────────────────────────────────────
# Path to Kokoro MLX model directory.
# KOKORO_MODEL_PATH=$HOME/models/tts/Kokoro-82M-bf16

# Path to Kokoro ONNX model and voices files.
# KOKORO_ONNX_MODEL_PATH=$HOME/models/tts/kokoro-v1.0.onnx
# KOKORO_ONNX_VOICES_PATH=$HOME/models/tts/voices-v1.0.bin

# Force Kokoro ONNX backend even on Apple Silicon (set by run-parlor.sh).
# KOKORO_ONNX=

# ── macOS system TTS ────────────────────────────────────────────────
# SYSTEM_TTS_VOICE=Tingting
# SYSTEM_TTS_RATE=180
